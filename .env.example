# ============================================================
# Clubs 2.0 — Production Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=clubs
POSTGRES_USER=clubs
POSTGRES_PASSWORD=Crbgtlfh12!!

# --- Redis ---
# (no extra vars needed — host/port are hardcoded in docker-compose.prod.yml)

# --- MinIO (S3-compatible file storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=Crbgtlfh12!!
S3_BUCKET=clubs-uploads
# S3_BASE_URL: leave unset for prod/staging — backend returns relative URLs
# like "/uploads/<uuid>.png" and frontend nginx proxies them to internal MinIO.
# Only set this when MinIO is exposed publicly via its own hostname.
# S3_BASE_URL=

# --- Backend ---
JWT_SECRET=a1eb1abd26e4246697c3fb269073dba5
JWT_EXPIRATION=86400000

# --- Telegram ---
TELEGRAM_BOT_TOKEN=<your-bot-token>

# --- Traefik (unique per environment to avoid routing conflicts) ---
# Production:  TRAEFIK_SERVICE_NAME=clubs-frontend-prod
# Staging:     TRAEFIK_SERVICE_NAME=clubs-frontend-staging
TRAEFIK_SERVICE_NAME=clubs-frontend-prod
