# ============================================================
# Clubs 2.0 — Production Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=clubs
POSTGRES_USER=clubs
POSTGRES_PASSWORD=<set-strong-password>

# --- Redis ---
# (no extra vars needed — host/port are hardcoded in docker-compose.prod.yml)

# --- MinIO (S3-compatible file storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<set-strong-password>
S3_BUCKET=clubs-uploads
# S3_BASE_URL: leave unset for prod/staging — backend returns relative URLs
# like "/uploads/<uuid>.png" and frontend nginx proxies them to internal MinIO.
# Only set this when MinIO is exposed publicly via its own hostname.
# S3_BASE_URL=

# --- Backend ---
JWT_SECRET=<generate: openssl rand -hex 32>
JWT_EXPIRATION=86400000

# --- Telegram ---
TELEGRAM_BOT_TOKEN=<your-bot-token>

# --- Yandex Maps (event-geo) ---
# Публичные фронтовые ключи (инлайнятся в JS-бандл), три ОТДЕЛЬНЫХ продукта кабинета
# developer.tech.yandex.ru: «JavaScript API» (v2.1, карта пикера), «Static API» (мини-карта),
# «API Геокодера» (поиск адреса). Защита — referer-ограничение в кабинете.
VITE_YANDEX_MAPS_API_KEY=<yandex-js-api-key>
VITE_YANDEX_STATIC_API_KEY=<yandex-static-api-key>
VITE_YANDEX_GEOCODER_API_KEY=<yandex-geocoder-api-key>
# Бэкенд-ключ Static API для карты в DM бота: ВТОРОЙ ключ того же продукта «Static API»,
# но БЕЗ referer-ограничений (Telegram скачивает картинку без referer). НЕ фронтовый ключ!
YANDEX_STATIC_API_KEY=<yandex-static-api-key-no-referer>
