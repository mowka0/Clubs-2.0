#!/usr/bin/env bash
# Pre-commit hook: ловит секреты в staged-изменениях до того, как они попадут в git-историю.
#
# Активация один раз на свежем clone:
#   git config core.hooksPath .githooks
#
# Требует `gitleaks` в PATH. Установка на macOS: brew install gitleaks
# Если gitleaks не установлен — hook предупреждает и пропускает коммит:
# источник истины — CI (.github/workflows/secret-scan.yml).

set -e

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks not installed — skipping local secret scan."
  echo "   Install: brew install gitleaks  (CI will still scan)"
  exit 0
fi

gitleaks protect --staged --no-banner --redact --verbose
