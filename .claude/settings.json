{
  "permissions": {
    "allow": [
      "Bash(./gradlew build:*)",
      "Bash(docker compose:*)",
      "Bash(python3 -c \":*)",
      "Bash(npm run:*)",
      "Read(//private/tmp/**)",
      "Bash(CLUB_ID=\"52fe1644-8a1b-4738-a353-81de3eeaed1f\" curl -s \"http://localhost:8080/api/clubs/$CLUB_ID\")",
      "Bash(python3 -m json.tool)",
      "Bash(npx tsc:*)",
      "Bash(./gradlew compileKotlin --no-daemon)",
      "Bash(./gradlew compileKotlin --no-daemon --info)",
      "Bash(./gradlew compileKotlin)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cd:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git --no-pager log:*)",
      "Bash(git --no-pager diff:*)",
      "Bash(git --no-pager show:*)",
      "Bash(git --no-pager branch:*)",
      "Bash(git --no-pager status:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/safety-guard.py\"",
            "statusMessage": "safety-guard"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/safety-guard.py\"",
            "statusMessage": "safety-guard"
          }
        ]
      }
    ]
  }
}
